# Chezmoi Environment Configuration
# Copy this file to .env and customize as needed
# .env is ignored by chezmoi and git

# Additional chezmoi flags (applied to all commands)
# CHEZMOI_FLAGS=--verbose

# Diff-specific flags
# CHEZMOI_DIFF_FLAGS=--reverse --pager=less

# Apply-specific flags
# CHEZMOI_APPLY_FLAGS=--dry-run

# Examples:
# - Dry run mode: CHEZMOI_APPLY_FLAGS=--dry-run
# - Exclude specific files: CHEZMOI_FLAGS=--exclude=scripts
# - Use specific config: CHEZMOI_FLAGS=--config=/path/to/config.toml
