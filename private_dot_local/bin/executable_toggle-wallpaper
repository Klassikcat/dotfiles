#!/bin/bash
# Toggle live wallpaper on/off

# Debug mode
DEBUG=false

# Parse arguments
for arg in "$@"; do
    case $arg in
        --debug)
            DEBUG=true
            ;;
    esac
done

# Get current theme state
current_theme=$(cat "$HOME/.cache/.theme_mode" 2>/dev/null || echo "Dark")

# swww settings
swww="swww img"
effect="--transition-bezier .43,1.19,1,.4 --transition-fps 60 --transition-type grow --transition-pos 0.925,0.977 --transition-duration 2"

# Wallpaper current file
wallpaper_current="$HOME/.config/hypr/wallpaper_effects/.wallpaper_current"

# Check if mpvpaper is running
if pgrep -x "mpvpaper" > /dev/null; then
    # Live wallpaper is on, turn it off and show static wallpaper
    killall mpvpaper 2>/dev/null
    
    # Use the current wallpaper file
    if [ -f "$wallpaper_current" ]; then
        static_wallpaper="$wallpaper_current"
    else
        # Fallback based on theme
        if [ "$current_theme" = "Dark" ]; then
            static_wallpaper="$HOME/Pictures/wallpapers/Dynamic-Wallpapers/Dark/Screenshot from 2025-11-04 21-19-01.png"
        else
            static_wallpaper="$HOME/Pictures/wallpapers/Dynamic-Wallpapers/Light/wallpaper48.png"
        fi
    fi
    
    # Start swww daemon if not running
    if $DEBUG; then
        swww query || swww-daemon --format xrgb &
    else
        swww query &>/dev/null || swww-daemon --format xrgb &>/dev/null &
    fi
    
    # Wait a moment for daemon to start
    sleep 0.3
    
    # Set static wallpaper
    if $DEBUG; then
        $swww "$static_wallpaper" $effect
        echo "Static wallpaper set: $static_wallpaper"
    else
        $swww "$static_wallpaper" $effect &>/dev/null
    fi
    
    notify-send -u low "Live Wallpaper" "Turned off"
else
    toggle-theme "${current_theme,,}" system
    notify-send -u low "Live Wallpaper" "Turned on"
    notify-send -u low "Live Wallpaper" "Automatically changes with theme."
fi
