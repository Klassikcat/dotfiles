alias catmocha="bat --theme='Catppuccin Mocha' --paging=never"      # Force dark theme
alias catfrappe="bat --theme='Catppuccin Frappe' --paging=never"    # Force frappe theme
alias catmacchiato="bat --theme='Catppuccin Macchiato' --paging=never" # Force macchiato theme

# Debug function to show current theme selection
cattime() {
    local hour=$(date +%H)
    local minute=$(date +%M)
    local minutes=$((10#$hour * 60 + 10#$minute))
    
    echo "Current time: ${hour}:${minute} (${minutes} minutes since midnight)"
    
    if [[ $minutes -ge 360 && $minutes -lt 1200 ]]; then
        echo "Using: Catppuccin Latte (Light theme)"
        echo "Active period: 06:00 - 20:00"
    else
        echo "Using: Catppuccin Mocha (Dark theme)"
        echo "Active period: 20:00 - 06:00"
    fi
    
    if [[ $# -gt 0 ]]; then
        catppuccin_bat "$@"
    fi
}
