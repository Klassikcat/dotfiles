# Catppuccin theme switching based on GNOME system color scheme
catppuccin_bat() {
    # Get GNOME color scheme
    local color_scheme=$(gsettings get org.gnome.desktop.interface color-scheme 2>/dev/null)
    
    # Select theme based on system preference
    if [[ "$color_scheme" == "'prefer-light'" || "$color_scheme" == "'default'" ]]; then
        bat --theme="Catppuccin Latte" "$@"
    else
        bat --theme="Catppuccin Mocha" "$@"
    fi
}

# Enhanced aliases using Catppuccin themes
alias cat="catppuccin_bat --paging=never"
alias catn="catppuccin_bat --style=numbers --paging=never"
alias catg="catppuccin_bat --style=changes --paging=never"  
alias catl="catppuccin_bat"

