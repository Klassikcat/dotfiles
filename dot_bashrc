# Smart bat theme selection based on terminal background
smart_bat() {
    # Try to detect terminal background
    # This is a simple heuristic - you might need to adjust based on your terminal
    
    # Check if COLORFGBG is set (some terminals set this)
    if [[ -n "$COLORFGBG" ]]; then
        # COLORFGBG format: foreground;background
        bg_color=${COLORFGBG##*;}
        if [[ $bg_color -lt 8 ]]; then
            # Dark background
            bat --theme="Dracula" "$@"
        else
            # Light background
            bat --theme="GitHub" "$@"
        fi
    # Check terminal name for known light/dark themes
    elif [[ "$TERM_PROGRAM" == "vscode" ]] || [[ "$COLORTERM" == "truecolor" ]]; then
        # Default to auto-detection or user preference
        # You can customize this part
        bat --theme="OneHalfDark" "$@"
    else
        # Fallback to default bat behavior
        bat "$@"
    fi
}

# Enhanced aliases with smart theme selection
alias catsmart="smart_bat --paging=never"
