#!/usr/bin/env python3
# chezmoi:template:left-delimiter="{{" right-delimiter="}}"
"""
Modify script for codex config - only manages [mcp_servers] section.
Other sections (projects, model settings, tui, notice, etc.) are preserved
verbatim from the existing file, including comments and ordering.
"""

import re
import sys

# MCP servers configuration (managed by chezmoi)
MANAGED_MCP_SERVERS = {
    "playwright": {
        "command": "npx",
        "args": ["-y", "@playwright/mcp"]
    },
    "kubernetes": {
        "command": "npx",
        "args": ["-y", "kubernetes-mcp-server@latest"]
    },
    "terraform": {
        "command": "{{ .chezmoi.homeDir }}/.local/share/mcp-servers/terraform-mcp-server",
        "args": ["stdio"]
    },
    "aws-serverless": {
        "command": "{{ .chezmoi.homeDir }}/.local/bin/awslabs.aws-serverless-mcp-server"
    },
    "iam-blackcircles-develop": {
        "command": "{{ .chezmoi.homeDir }}/.local/bin/awslabs.iam-mcp-server",
        "args": ["--allow-write"],
        "env": {
            "AWS_PROFILE": "blackcircles-develop",
            "AWS_REGION": "ap-northeast-2"
        }
    },
    "iam-blackcircles-prod-readonly": {
        "command": "{{ .chezmoi.homeDir }}/.local/bin/awslabs.iam-mcp-server",
        "env": {
            "AWS_PROFILE": "blackcircles-prod",
            "AWS_REGION": "ap-northeast-2"
        }
    },
    "iam-tirepick": {
        "command": "{{ .chezmoi.homeDir }}/.local/bin/awslabs.iam-mcp-server",
        "args": ["--allow-write"],
        "env": {
            "AWS_PROFILE": "tirepick",
            "AWS_REGION": "ap-northeast-2"
        }
    },
    "iam-control-plane": {
        "command": "{{ .chezmoi.homeDir }}/.local/bin/awslabs.iam-mcp-server",
        "args": ["--allow-write"],
        "env": {
            "AWS_PROFILE": "control-plane",
            "AWS_REGION": "ap-northeast-2"
        }
    },
    "code-review-graph": {
        "command": "{{ .chezmoi.homeDir }}/.local/bin/code-review-graph",
        "args": ["serve"]
    }
}


def format_toml_value(v):
    if isinstance(v, bool):
        return "true" if v else "false"
    if isinstance(v, str):
        escaped = v.replace("\\", "\\\\").replace('"', '\\"')
        return f'"{escaped}"'
    if isinstance(v, list):
        return "[" + ", ".join(format_toml_value(x) for x in v) + "]"
    return str(v)


def render_mcp_servers(servers):
    blocks = []
    for name, cfg in servers.items():
        lines = [f"[mcp_servers.{name}]"]
        for k, v in cfg.items():
            if k == "env":
                continue
            lines.append(f"{k} = {format_toml_value(v)}")
        if "env" in cfg:
            lines.append("")
            lines.append(f"  [mcp_servers.{name}.env]")
            for ek, ev in cfg["env"].items():
                lines.append(f"  {ek} = {format_toml_value(ev)}")
        blocks.append("\n".join(lines))
    return "\n\n".join(blocks)


SECTION_RE = re.compile(r"^\s*\[([^\]]+)\]")


def strip_mcp_servers(text):
    """Remove [mcp_servers...] sections, return (remaining_lines, insert_index)."""
    lines = text.splitlines()
    out = []
    in_mcp = False
    insert_idx = None
    for line in lines:
        m = SECTION_RE.match(line)
        if m:
            header = m.group(1).strip()
            is_mcp = header == "mcp_servers" or header.startswith("mcp_servers.")
            if is_mcp:
                in_mcp = True
                if insert_idx is None:
                    insert_idx = len(out)
                continue
            in_mcp = False
        if in_mcp:
            continue
        out.append(line)
    return out, insert_idx


def main():
    existing = sys.stdin.read()
    remaining, insert_idx = strip_mcp_servers(existing)
    managed = render_mcp_servers(MANAGED_MCP_SERVERS)

    if insert_idx is None:
        while remaining and not remaining[-1].strip():
            remaining.pop()
        chunks = []
        if remaining:
            chunks.append("\n".join(remaining))
        chunks.append(managed)
        sys.stdout.write("\n\n".join(chunks) + "\n")
        return

    before = remaining[:insert_idx]
    after = remaining[insert_idx:]
    while before and not before[-1].strip():
        before.pop()
    while after and not after[0].strip():
        after.pop(0)

    chunks = []
    if before:
        chunks.append("\n".join(before))
    chunks.append(managed)
    if after:
        chunks.append("\n".join(after))
    sys.stdout.write("\n\n".join(chunks) + "\n")


if __name__ == "__main__":
    main()
