{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "{{ .chezmoi.homeDir }}"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "{{ env "GITHUB_TOKEN" }}"
      }
    },
    "terraform": {
      "command": "{{ .chezmoi.homeDir }}/.local/share/mcp-servers/terraform-mcp-server",
      "args": ["stdio"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    },
    "kubernetes": {
      "command": "npx",
      "args": ["-y", "kubernetes-mcp-server@latest"]
    },
    "aws-serverless": {
      "command": "awslabs.aws-serverless-mcp-server"
    },
    "serverless": {
      "command": "npx",
      "args": ["-y", "serverless", "mcp"]
    },
    "code-review-graph": {
      "command": "code-review-graph",
      "args": ["serve"]
    }
  }
}
