{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-openai-codex-auth",
    "oh-my-opencode"
  ],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": true
    },
    "kubernetes": {
      "type": "local",
      "command": [
        "{{ .chezmoi.homeDir }}/mcp-servers/kubernetes-mcp-server/k8s-mcp-server"
      ],
      "enabled": true
    },
    "terraform": {
      "type": "local",
      "command": [
        "{{ .chezmoi.homeDir }}/mcp-servers/terraform-mcp-server/terraform-mcp-server"
      ],
      "enabled": true
    },
    "aws-serverless": {
      "type": "local",
      "command": [
        "{{ .chezmoi.homeDir }}/mcp-servers/venv/bin/awslabs.aws-serverless-mcp-server"
      ],
      "enabled": true
    },
    "iam-blackcircles-develop": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.iam-mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "AWS_PROFILE": "blackcircles-develop",
        "AWS_REGION": "ap-northeast-2"
      }
    },
    "iam-blackcircles-prod-readonly": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.iam-mcp-server@latest",
        "--readonly"
      ],
      "enabled": true,
      "environment": {
        "AWS_PROFILE": "blackcircles-prod",
        "AWS_REGION": "ap-northeast-2"
      }
    },
    "iam-tirepick": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.iam-mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "AWS_PROFILE": "tirepick",
        "AWS_REGION": "ap-northeast-2"
      }
    },
    "iam-control-plane": {
      "type": "local",
      "command": [
        "uvx",
        "awslabs.iam-mcp-server@latest"
      ],
      "enabled": true,
      "environment": {
        "AWS_PROFILE": "control-plane",
        "AWS_REGION": "ap-northeast-2"
      }
    }
  },
  "provider": {
    "openai": {
      "name": "OpenAI",
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": ["reasoning.encrypted_content"],
        "store": false
      },
      "models": {
        "gpt-5.2": {
          "name": "GPT 5.2 (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.2-codex": {
          "name": "GPT 5.2 Codex (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.1-codex-max": {
          "name": "GPT 5.1 Codex Max (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        }
      }
    }
  }
}
