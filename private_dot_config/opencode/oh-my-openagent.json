{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "team_mode": {
    "enabled": true,
    "max_parallel_members": 4,
    "tmux_visualization": true
  },
  "google_auth": false,
  "agents": {
    "sisyphus": {
      "model": "openrouter/z-ai/glm-5.2",
      "fallback_models": [
        "openrouter/moonshotai/kimi-k2.6",
        "openrouter/deepseek/deepseek-v4-pro"
      ],
      "textVerbosity": "low",
      "provider": {
        "sort": "latency"
      }
    },
    "librarian": {
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "fallback_models": ["openrouter/minimax/minimax-m2.7"]
    },
    "prometheus": {
      "model": "openrouter/z-ai/glm-5.2",
      "fallback_models": [
        "openrouter/z-ai/glm-5.1",
        "openrouter/moonshotai/kimi-k2.6"
      ],
      "reasoningEffort": "high",
      "textVerbosity": "low"
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "medium",
      "textVerbosity": "low"
    },
    "metis": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh",
      "textVerbosity": "low"
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh",
      "textVerbosity": "low"
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh",
      "textVerbosity": "low"
    },
    "explore": {
      "model": "openrouter/deepseek/deepseek-v4-flash",
      "fallback_models": ["openrouter/minimax/minimax-m2.7"]
    },
    "frontend-ui-ux-engineer": {
      "model": "openrouter/moonshotai/kimi-k2.6",
      "fallback_models": ["openrouter/google/gemini-3.1-pro-preview"],
      "textVerbosity": "low"
    },
    "document-writer": {
      "model": "openrouter/z-ai/glm-5.1",
      "fallback_models": ["openrouter/deepseek/deepseek-v4-flash"]
    },
    "multimodal-looker": {
      "model": "openrouter/google/gemini-3.1-flash-lite-preview"
    },
    "atlas": {
      "model": "openai/gpt-5.5",
      "fallback_models": ["openrouter/moonshotai/kimi-k2.6"],
      "textVerbosity": "low",
      "reasoningEffort": "medium"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.5",
      "fallback_models": ["openrouter/openai/gpt-oss-120b"],
      "reasoningEffort": "low",
      "textVerbosity": "low"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "openrouter/google/gemini-3.1-pro-preview"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5"
    },
    "deep": {
      "model": "openai/gpt-5.5"
    },
    "artistry": {
      "model": "openrouter/google/gemini-3.1-pro-preview"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4-mini"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.5"
    },
    "writing": {
      "model": "openrouter/z-ai/glm-5.1"
    }
  }
}
