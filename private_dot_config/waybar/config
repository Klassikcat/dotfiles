{
    "layer": "top",
    "position": "top",
    "margin": "5 5 0 5",
    "modules-left": ["hyprland/workspaces"],
    "modules-center": ["custom/music"],
    "modules-right": ["tray", "clock", "custom/light_dark", "custom/lock", "custom/power"],
    "hyprland/workspaces": {
         "disable-scroll": false,
         "all-outputs": true,
         "format": "{icon}",
         "format-icons": {
             "active": "",
             "default": ""
         },
     },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "custom/music": {
        "format": "пҖҒ  {}",
        "escape": true,
        "interval": 5,
        "tooltip": false,
        "exec": "playerctl metadata --format='{{ title }}'",
        "on-click": "playerctl play-pause",
        "max-length": 50
    },
    "clock": {
        "timezone": "Asia/Dubai",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "п—¬ {:%d/%m/%Y}",
        "format": "пҷҸ {:%H:%M}"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-icons": ["оҺҚ", "оҸ“", "оҸ‘", "оҸҸ", "оҸҺ", "оҸҚ", "оҸҠ", "оҸҲ", "оҺӣ"]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-charging": "п–ғ",
        "format-plugged": "п–ғ",
        "format-alt": "{icon}",
        "format-icons": ["п–Ӯ", "п•№",  "п•ә", "п•»", "п•ј", "п•Ҫ", "п•Ҫ", "п•ҫ", "п•ҝ", "п–Җ", "п–Ғ", "п•ё"]
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon} {volume}%",
        "format-muted": "п‘Ұ",
        "format-icons": {
            "default": ["пҖҰ", "пҖ§", "пҖЁ "]
        },
        "on-click": "pavucontrol"
    },
    "custom/light_dark": {
        "format": "у°”Һ",
        "on-click": "$HOME/.config/hypr/scripts/DarkLight.sh",
        "tooltip": true,
        "tooltip-format": "Switch Theme"
    },
    "custom/lock": {
        "tooltip": false,
        "on-click": "$HOME/.config/hypr/scripts/LockScreen.sh",
        "format": ""
    },
    "custom/power": {
        "tooltip": false,
        "on-click": "$HOME/.config/hypr/scripts/Wlogout.sh",
        "format": "вҸ»"
    }
}
